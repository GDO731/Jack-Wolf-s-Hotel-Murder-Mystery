--- !u!114 &-3642404422460705698
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2af882ccae0e519489bfd08f9f4633a4, type: 3}
  m_Name: cae61f10-f720-43e0-b615-616ed8c1dc00
  m_EditorClassIdentifier: Assembly-CSharp::Assets.Game.Scripts.Dialogue.DialogueNode
  isPlayerSpeaking: 0
  text: Sir, if you think I killed this man, you are mistaken. I am too old to hurt
    anyone in my age. I don't appreciate what you are insinuating. (Shambles off)
  audioClip: {fileID: 0}
  animation: {fileID: 0}
  children: []
