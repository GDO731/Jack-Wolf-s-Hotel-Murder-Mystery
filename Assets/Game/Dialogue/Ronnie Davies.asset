  onExitAction: 
--- !u!114 &4500546438378084686
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2af882ccae0e519489bfd08f9f4633a4, type: 3}
  m_Name: a8492415-ab96-4c65-aa98-66c853b2f6ed
  m_EditorClassIdentifier: Assembly-CSharp::Assets.Game.Scripts.Dialogue.DialogueNode
  isPlayerSpeaking: 0
  text: "I heard a loud noise earlier\u2026 Thought it was the storm up to their
    old tricks. I went to tidy up the shed\u2026 found him in the mud. Wrapped up
    like rubbish."
  audioClip: {fileID: 0}
  animation: {fileID: 0}
  children:
  - 7d786d03-5e36-4630-b126-4b9c0a600064
  - 9f33131e-ae94-4d3b-81f6-d258d5800458
