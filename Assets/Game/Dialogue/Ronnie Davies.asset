--- !u!114 &766389892839670889
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2af882ccae0e519489bfd08f9f4633a4, type: 3}
  m_Name: d51ff27f-cf4a-4dc6-9545-7ce27d83bfba
  m_EditorClassIdentifier: Assembly-CSharp::Assets.Game.Scripts.Dialogue.DialogueNode
  isPlayerSpeaking: 0
  text: Everything I said is true, I went to tidy up the shed and found this man
    in the mud.. It's a shame for someone as young as him, so much time gone.. (Weeze)
  audioClip: {fileID: 0}
  animation: {fileID: 0}
  children:
  - ed4bcd61-0793-49b9-af96-dc63dae1792c
  rect:
    serializedVersion: 2
    x: 752
    y: 46
    width: 300
    height: 125
