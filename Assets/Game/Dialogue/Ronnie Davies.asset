--- !u!114 &5541362398645264874
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2af882ccae0e519489bfd08f9f4633a4, type: 3}
  m_Name: bb1e0c60-4271-4572-a515-79b53c01eb25
  m_EditorClassIdentifier: Assembly-CSharp::Assets.Game.Scripts.Dialogue.DialogueNode
  isPlayerSpeaking: 0
  text: In my old age you see much death young man.. Time isn't kind to us as we
    get old, you shouldn't waste it.
  audioClip: {fileID: 0}
  animation: {fileID: 0}
  children:
  - daccf955-f227-4b81-b60c-9d5f035e6754
